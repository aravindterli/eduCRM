generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  type        RoleType
  permissions Json?
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  sector    Sector   @default(EDUCATION)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  roles                  Role[]
  invitations            Invitation[]
  leads                  Lead[]
  programs               Program[]
  campaigns              Campaign[]
  marketingCampaigns     MarketingCampaign[]
  webinars               Webinar[]
  notifications          Notification[]
  followUps              FollowUp[]
  counselingLogs         CounselingLog[]
  applications           Application[]
  auditLogs              AuditLog[]
  communicationLogs      CommunicationLog[]
  leadNotes              LeadNote[]
  messageTemplates       MessageTemplate[]
  notificationRules      NotificationRule[]
  scheduledNotifications ScheduledNotification[]
  admissions             Admission[]
  fees                   Fee[]
  payments               Payment[]
  webinarRegistrations   WebinarRegistration[]
  formTemplates          FormTemplate[]

  // Billing Fields
  subscriptionStatus     String   @default("ACTIVE") // ACTIVE, TRIAL, SUSPENDED
  subscriptionPlan       String   @default("FREE")
  nextBillingDate        DateTime?
}

model FormTemplate {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  sector      Sector
  fields      Json     // Array of field objects {name, label, type, required, options[]}
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id                 String             @id @default(uuid())
  name               String
  email              String             @unique
  password           String
  roleId             String
  tenantId           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  accent             String             @default("blue")
  theme              String             @default("ocean")
  communicationLogs  CommunicationLog[] @relation("AssignedComms")
  counselingSessions CounselingLog[]    @relation("AssignedSessions")
  followUps          FollowUp[]         @relation("AssignedFollowUps")
  createdFollowUps   FollowUp[]         @relation("CreatedFollowUps")
  leads              Lead[]             @relation("AssignedLeads")
  leadNotes          LeadNote[]         @relation("AssignedNotes")
  notifications      Notification[]
  role               Role               @relation(fields: [roleId], references: [id])
  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Invitation {
  id           String   @id @default(uuid())
  email        String
  tenantId     String
  roleId       String
  token        String   @unique
  status       String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  tenantId    String
  taskId      String?
  leadId      String?
  title       String
  message     String
  type        String    @default("FOLLOW_UP")
  isRead      Boolean   @default(false)
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model Program {
  id           String        @id @default(uuid())
  tenantId     String
  name         String
  description  String?
  baseFee      Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  admissions   Admission[]
  applications Application[]
  leads        Lead[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Campaign {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  source    String
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  leads     Lead[]
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model MarketingCampaign {
  id             String    @id @default(uuid())
  tenantId       String
  name           String
  channel        String
  source         String?
  templateId     String?
  audienceFilters Json?
  scheduledAt    DateTime?
  status         String    @default("DRAFT")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  leads          Lead[]    @relation("MarketingCampaignLeads")
  scheduledNotifications ScheduledNotification[]
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Lead {
  id                     String                  @id @default(uuid())
  tenantId               String
  name                   String
  phone                  String
  email                  String?
  location               String?
  eduBackground          String?
  qualification          String?
  interestedProgramId    String?
  leadSource             String
  campaignId             String?
  marketingCampaignId    String?
  enquiryDate            DateTime                @default(now())
  stage                  String                  @default("NEW")
  priority               Int                     @default(0)

  assignedId             String?                 @map("counselorId")
  additionalData         Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  application            Application?
  communicationLogs      CommunicationLog[]
  counselingLogs         CounselingLog[]
  followUps              FollowUp[]
  campaign               Campaign?               @relation(fields: [campaignId], references: [id])
  marketingCampaign      MarketingCampaign?      @relation("MarketingCampaignLeads", fields: [marketingCampaignId], references: [id])
  assignedTo             User?                   @relation("AssignedLeads", fields: [assignedId], references: [id])
  program                Program?                @relation(fields: [interestedProgramId], references: [id])
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notes                  LeadNote[]
  webinarRegistrations   WebinarRegistration[]
  scheduledNotifications ScheduledNotification[]

  @@index([phone])
  @@index([email])
  @@index([tenantId])
}

model FollowUp {
  id          String    @id @default(uuid())
  tenantId    String
  leadId      String
  assignedId  String    @map("counselorId")
  notes       String?
  scheduledAt DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  meetingUrl  String?
  createdById String?
  assignedTo  User      @relation("AssignedFollowUps", fields: [assignedId], references: [id])
  createdBy   User?     @relation("CreatedFollowUps", fields: [createdById], references: [id])
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Webinar {
  id            String                @id @default(uuid())
  tenantId      String
  title         String
  description   String?
  date          DateTime
  createdAt     DateTime              @default(now())
  meetingId     String?
  meetingUrl    String?
  registrations WebinarRegistration[]
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model WebinarRegistration {
  id        String   @id @default(uuid())
  tenantId  String
  webinarId String
  leadId    String
  attended  Boolean  @default(false)
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  webinar   Webinar  @relation(fields: [webinarId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CounselingLog {
  id             String   @id @default(uuid())
  tenantId       String
  leadId         String
  assignedId     String   @map("counselorId")
  notes          String?
  recommendation String?
  createdAt      DateTime @default(now())
  assignedTo     User     @relation("AssignedSessions", fields: [assignedId], references: [id])
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Application {
  id          String            @id @default(uuid())
  tenantId    String
  leadId      String            @unique
  programId   String
  status      ApplicationStatus @default(STARTED)
  submittedAt DateTime?
  createdAt   DateTime          @default(now())
  admission   Admission?
  lead        Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  program     Program           @relation(fields: [programId], references: [id])
  documents   Document[]
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Document {
  id            String      @id @default(uuid())
  applicationId String
  type          String
  url           String
  name          String      @default("Document")
  status        String      @default("PENDING")
  remarks       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Admission {
  id            String      @id @default(uuid())
  tenantId      String
  applicationId String      @unique
  enrollmentId  String      @unique
  programId     String
  admittedAt    DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  program       Program     @relation(fields: [programId], references: [id])
  fees          Fee[]
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Fee {
  id          String    @id @default(uuid())
  tenantId    String
  admissionId String
  amount      Float
  dueDate     DateTime?
  status      String
  createdAt   DateTime  @default(now())
  admission   Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  payments    Payment[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(uuid())
  tenantId      String
  feeId         String
  amount        Float
  method        String
  transactionId String?
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  fee           Fee           @relation(fields: [feeId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String
  details   Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CommunicationLog {
  id         String   @id @default(uuid())
  tenantId   String
  leadId     String
  type       String
  direction  String
  message    String
  status     String
  timestamp  DateTime @default(now())
  assignedId String?  @map("counselorId")
  duration   Int?
  result     String?
  assignedTo User?    @relation("AssignedComms", fields: [assignedId], references: [id])
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LeadNote {
  id         String       @id @default(uuid())
  tenantId   String
  leadId     String
  assignedId String       @map("counselorId")
  content    String
  createdAt  DateTime     @default(now())
  type       LeadNoteType @default(GENERAL)
  assignedTo User         @relation("AssignedNotes", fields: [assignedId], references: [id])
  lead       Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model MessageTemplate {
  id                String             @id @default(uuid())
  tenantId          String
  name              String             @unique
  channel           String
  subject           String?
  content           String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  notificationRules NotificationRule[]
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum LeadNoteType {
  GENERAL
  REMARK
  STUDENT_FEEDBACK
  DISCUSSION_SUMMARY
}

enum RoleType {
  SUPERADMIN
  ADMIN
  STANDARDUSER
}

enum Sector {
  EDUCATION
  REAL_ESTATE
  HEALTHCARE
  GENERIC
}





enum ApplicationStatus {
  STARTED
  SUBMITTED
  VERIFICATION_PENDING
  VERIFIED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model NotificationRule {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  trigger     String
  channel     String
  templateId  String?
  offsets     Int[]    @default([0])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template MessageTemplate? @relation(fields: [templateId], references: [id])
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ScheduledNotification {
  id          String    @id @default(uuid())
  tenantId    String
  ruleId      String?
  trigger     String
  channel     String
  recipientId String?
  contactInfo String?
  templateId  String?
  templateKey String?
  subject     String?
  body        String?
  payload     Json?
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("PENDING")
  retryCount  Int       @default(0)
  errorLog    String?
  leadId      String?
  marketingCampaignId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead              Lead?              @relation(fields: [leadId], references: [id])
  marketingCampaign MarketingCampaign? @relation(fields: [marketingCampaignId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ConnectorDefinition {
  id           String   @id
  name         String
  category     String?
  logo         String?
  fields       Json
  instructions Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
