generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  type        RoleType @unique
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id                 String             @id @default(uuid())
  name               String
  email              String             @unique
  password           String
  roleId             String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  accent             String             @default("blue")
  theme              String             @default("ocean")
  communicationLogs  CommunicationLog[] @relation("AssignedComms")
  counselingSessions CounselingLog[]    @relation("AssignedSessions")
  followUps          FollowUp[]         @relation("AssignedFollowUps")
  createdFollowUps   FollowUp[]         @relation("CreatedFollowUps")
  leads              Lead[]             @relation("AssignedLeads")
  leadNotes          LeadNote[]         @relation("AssignedNotes")
  notifications      Notification[]
  role               Role               @relation(fields: [roleId], references: [id])
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  taskId      String?
  leadId      String?
  title       String
  message     String
  type        String    @default("FOLLOW_UP")
  isRead      Boolean   @default(false)
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Program {
  id           String        @id @default(uuid())
  name         String
  description  String?
  baseFee      Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  admissions   Admission[]
  applications Application[]
  leads        Lead[]
}

model Campaign {
  id        String    @id @default(uuid())
  name      String
  source    String
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  leads     Lead[]
}

model Lead {
  id                   String                @id @default(uuid())
  name                 String
  phone                String
  email                String?
  location             String?
  eduBackground        String?
  qualification        String?
  interestedProgramId  String?
  leadSource           String
  campaignId           String?
  enquiryDate          DateTime              @default(now())
  stage                LeadStage             @default(NEW_LEAD)
  priority             Int                   @default(0)
  tag                  LeadTag?
  assignedId           String?               @map("counselorId")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  application          Application?
  communicationLogs    CommunicationLog[]
  counselingLogs       CounselingLog[]
  followUps            FollowUp[]
  campaign             Campaign?             @relation(fields: [campaignId], references: [id])
  assignedTo           User?                 @relation("AssignedLeads", fields: [assignedId], references: [id])
  program              Program?              @relation(fields: [interestedProgramId], references: [id])
  notes                LeadNote[]
  webinarRegistrations WebinarRegistration[]
  scheduledNotifications ScheduledNotification[]


  @@index([phone])
  @@index([email])
}

model FollowUp {
  id          String    @id @default(uuid())
  leadId      String
  assignedId  String    @map("counselorId")
  notes       String?
  scheduledAt DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  meetingUrl  String?
  createdById String?
  assignedTo  User      @relation("AssignedFollowUps", fields: [assignedId], references: [id])
  createdBy   User?     @relation("CreatedFollowUps", fields: [createdById], references: [id])
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Webinar {
  id            String                @id @default(uuid())
  title         String
  description   String?
  date          DateTime
  createdAt     DateTime              @default(now())
  meetingId     String?
  meetingUrl    String?
  registrations WebinarRegistration[]
}

model WebinarRegistration {
  id        String   @id @default(uuid())
  webinarId String
  leadId    String
  attended  Boolean  @default(false)
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  webinar   Webinar  @relation(fields: [webinarId], references: [id])
}

model CounselingLog {
  id             String   @id @default(uuid())
  leadId         String
  assignedId     String   @map("counselorId")
  notes          String?
  recommendation String?
  createdAt      DateTime @default(now())
  assignedTo     User     @relation("AssignedSessions", fields: [assignedId], references: [id])
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Application {
  id          String            @id @default(uuid())
  leadId      String            @unique
  programId   String
  status      ApplicationStatus @default(STARTED)
  submittedAt DateTime?
  createdAt   DateTime          @default(now())
  admission   Admission?
  lead        Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  program     Program           @relation(fields: [programId], references: [id])
  documents   Document[]
}

model Document {
  id            String      @id @default(uuid())
  applicationId String
  type          String
  url           String
  name          String      @default("Document")
  status        String      @default("PENDING")
  remarks       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Admission {
  id            String      @id @default(uuid())
  applicationId String      @unique
  enrollmentId  String      @unique
  programId     String
  admittedAt    DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  program       Program     @relation(fields: [programId], references: [id])
  fees          Fee[]
}

model Fee {
  id          String    @id @default(uuid())
  admissionId String
  amount      Float
  dueDate     DateTime?
  status      String
  createdAt   DateTime  @default(now())
  admission   Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  payments    Payment[]
}

model Payment {
  id            String        @id @default(uuid())
  feeId         String
  amount        Float
  method        String
  transactionId String?
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  fee           Fee           @relation(fields: [feeId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   Json?
  createdAt DateTime @default(now())
}

model CommunicationLog {
  id         String   @id @default(uuid())
  leadId     String
  type       String
  direction  String
  message    String
  status     String
  timestamp  DateTime @default(now())
  assignedId String?  @map("counselorId")
  duration   Int?
  result     String?
  assignedTo User?    @relation("AssignedComms", fields: [assignedId], references: [id])
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadNote {
  id         String       @id @default(uuid())
  leadId     String
  assignedId String       @map("counselorId")
  content    String
  createdAt  DateTime     @default(now())
  type       LeadNoteType @default(GENERAL)
  assignedTo User         @relation("AssignedNotes", fields: [assignedId], references: [id])
  lead       Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model MessageTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  channel   String
  subject   String?
  content   String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  notificationRules NotificationRule[]
}


enum LeadNoteType {
  GENERAL
  REMARK
  STUDENT_FEEDBACK
  DISCUSSION_SUMMARY
}

enum RoleType {
  ADMIN
  MARKETING_TEAM
  TELECALLER
  COUNSELOR
  FINANCE
}

enum LeadStage {
  NEW_LEAD
  CONTACT_ATTEMPTED
  RESPONDED
  INTERESTED
  COUNSELING_SCHEDULED
  WEBINAR_REGISTERED
  WEBINAR_ATTENDED
  APPLICATION_STARTED
  APPLICATION_SUBMITTED
  ADMISSION_CONFIRMED
  LOST_LEAD
  RE_ENGAGEMENT
}

enum LeadTag {
  HOT
  WARM
  COLD
}

enum ApplicationStatus {
  STARTED
  SUBMITTED
  VERIFICATION_PENDING
  VERIFIED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model NotificationRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  trigger     String
  channel     String
  templateId  String?
  offsets     Int[]    @default([0])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template    MessageTemplate? @relation(fields: [templateId], references: [id])
}

model ScheduledNotification {
  id          String   @id @default(uuid())
  ruleId      String?
  trigger     String
  channel     String
  recipientId String?
  contactInfo String?
  templateId  String?
  templateKey String?
  subject     String?
  body        String?
  payload     Json?
  scheduledAt DateTime
  sentAt      DateTime?
  status      String   @default("PENDING")
  retryCount  Int      @default(0)
  errorLog    String?
  leadId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead        Lead?    @relation(fields: [leadId], references: [id])
}

